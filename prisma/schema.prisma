generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum QuoteStatus {
  New
  InReview
  NeedsInfo
  Completed
}

model QuoteRequest {
  id              String         @id @default(cuid())
  customer        String
  project         String
  status          QuoteStatus    @default(New)
  estimated_value Float
  created_date    DateTime       @default(now())

  analysis        AnalysisResult?
}

model AnalysisResult {
  id             String        @id @default(cuid())
  quote_id       String        @unique
  risk           String
  confidence     Int
  missing_items  String
  analyzed_at    DateTime      @default(now())

  quote          QuoteRequest  @relation(fields: [quote_id], references: [id], onDelete: Cascade)
}